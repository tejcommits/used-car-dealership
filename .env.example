# Copy this file to .env and fill in real values.

# Login password for the admin (the dealer). Change this.
ADMIN_PASSWORD=changeme

# Secret key for sessions. Use a long random string in production.
SECRET_KEY=please-change-this-to-a-long-random-string

# Business details shown on the public site
BUSINESS_NAME=Pune Auto Deals
WHATSAPP_NUMBER=919999999999

# Set to 1 to run the scraper scheduler inside the web process.
# On a real server, prefer a cron job calling: python -m app.scrapers.run
RUN_SCHEDULER=0

# How often the scheduler scrapes, in hours (only used if RUN_SCHEDULER=1)
SCRAPE_INTERVAL_HOURS=12
